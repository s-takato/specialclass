powerdisp:false$/*##*/
display2d:false$/*##*/
linel:1000$/*##*/
batch("/Applications/KeTTeX.app/texlive/texmf-dist/scripts/ketcindy/ketlib/maximaL/mnr.max")$/*##*/
putT(m,n,r)$/*##*/
A:vtxT; B:vtxL; C:vtxR; I:inC$/*##*/
putT(m,n,s1*r); slideT(vtxL,B)$/*##*/
D:vtxT; Eb:vtxR; I1:inC$/*##*/
putT(m,n,s2*r); slideT(vtxR,C)$/*##*/
G:vtxT; Ec:vtxL; I2:inC$/*##*/
putT(m,n,s3*r); slideT(vtxT,A)$/*##*/
H:vtxL; J:vtxR; I3:inC$/*##*/
eq1:numer(lenSeg2(I1,I2)-(s1*r+s2*r)^2)$/*##*/
eq2:numer(lenSeg2(I2,I3)-(s2*r+s3*r)^2)$/*##*/
eq3:numer(lenSeg2(I3,I1)-(s3*r+s1*r)^2)$/*##*/
eq1:eq1/r^2$/*##*/
eq2:eq2/r^2$/*##*/
eq3:eq3/r^2$/*##*/
endstep$/*##*/
out12:reduceD([eq1,eq2],s2,8)$/*##*/
val12:factor(out12[2])$/*##*/
out13:reduceD([val12,eq3],s3,16)$/*##*/
val13:factor(out13[2])$/*##*/
subRule: [m=2*M/(1-M^2),n=2*N/(1-N^2)]$/*##*/
val13MN: factor(subst(subRule,val13))$/*##*/
val13MN: num(val13MN)$/*##*/
endstep$/*##*/
disp(A)$/*##*/
disp(B)$/*##*/
disp(C)$/*##*/
disp(I)$/*##*/
disp(D)$/*##*/
disp(Eb)$/*##*/
disp(G)$/*##*/
disp(Ec)$/*##*/
disp(H)$/*##*/
disp(J      )$/*##*/
disp(I1)$/*##*/
disp(I2)$/*##*/
disp(I3)$/*##*/
disp(eq1)$/*##*/
disp(eq2)$/*##*/
disp(eq3)$/*##*/
disp(eq1)$/*##*/
disp(eq2)$/*##*/
disp(eq3)$/*##*/
disp(val12)$/*##*/
disp(val13)$/*##*/
disp(val13MN)$/*##*/
closefile()$/*##*/
quit()$/*##*/
