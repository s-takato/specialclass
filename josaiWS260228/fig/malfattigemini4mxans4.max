val13MN:524288*M^2*N^3*(M*N-N-M-1)^5*(M*N+N+M-1)^5*(M^2*N*s1-N*s1-M^2*s1-2*M*s1-s1-M*N^2-M*N+N+1)*(M^2*N*s1-N*s1-M^2*s1-2*M*s1-s1-M*N^2-M^2*N+M*N+M^2)*(M^2*N*s1-N*s1+M^2*s1-2*M*s1+s1-M*N^2+M*N+N-1)*(M^2*N*s1-N*s1+M^2*s1-2*M*s1+s1-M*N^2-M^2*N-M*N-M^2)*(M^2*N^2*s1-2*M*N^2*s1+N^2*s1-M^2*N*s1+N*s1-N^2-M*N-N-M)*(M^2*N^2*s1-2*M*N^2*s1+N^2*s1-M^2*N*s1+N*s1-M^2*N^2+M^2*N+M*N-M)*(M^2*N^2*s1+2*M*N^2*s1+N^2*s1+M^2*N*s1-N*s1-N^2-M*N+N+M)*(M^2*N^2*s1+2*M*N^2*s1+N^2*s1+M^2*N*s1-N*s1-M^2*N^2-M^2*N+M*N+M)*(M^10*N^12*s1^2-4*M^8*N^12*s1^2+6*M^6*N^12*s1^2-4*M^4*N^12*s1^2+M^2*N^12*s1^2+2*M^11*N^11*s1^2-18*M^9*N^11*s1^2+44*M^7*N^11*s1^2-44*M^5*N^11*s1^2+18*M^3*N^11*s1^2-2*M*N^11*s1^2+M^12*N^10*s1^2-284*M^10*N^10*s1^2+1143*M^8*N^10*s1^2-1720*M^6*N^10*s1^2+1143*M^4*N^10*s1^2-284*M^2*N^10*s1^2+N^10*s1^2-18*M^11*N^9*s1^2+4258*M^9*N^9*s1^2-12684*M^7*N^9*s1^2+12684*M^5*N^9*s1^2-4258*M^3*N^9*s1^2+18*M*N^9*s1^2-4*M^12*N^8*s1^2+1143*M^10*N^8*s1^2-29176*M^8*N^8*s1^2+56074*M^6*N^8*s1^2-29176*M^4*N^8*s1^2+1143*M^2*N^8*s1^2-4*N^8*s1^2+44*M^11*N^7*s1^2-12684*M^9*N^7*s1^2+103368*M^7*N^7*s1^2-103368*M^5*N^7*s1^2+12684*M^3*N^7*s1^2-44*M*N^7*s1^2+6*M^12*N^6*s1^2-1720*M^10*N^6*s1^2+56074*M^8*N^6*s1^2-174256*M^6*N^6*s1^2+56074*M^4*N^6*s1^2-1720*M^2*N^6*s1^2+6*N^6*s1^2-44*M^11*N^5*s1^2+12684*M^9*N^5*s1^2-103368*M^7*N^5*s1^2+103368*M^5*N^5*s1^2-12684*M^3*N^5*s1^2+44*M*N^5*s1^2-4*M^12*N^4*s1^2+1143*M^10*N^4*s1^2-29176*M^8*N^4*s1^2+56074*M^6*N^4*s1^2-29176*M^4*N^4*s1^2+1143*M^2*N^4*s1^2-4*N^4*s1^2+18*M^11*N^3*s1^2-4258*M^9*N^3*s1^2+12684*M^7*N^3*s1^2-12684*M^5*N^3*s1^2+4258*M^3*N^3*s1^2-18*M*N^3*s1^2+M^12*N^2*s1^2-284*M^10*N^2*s1^2+1143*M^8*N^2*s1^2-1720*M^6*N^2*s1^2+1143*M^4*N^2*s1^2-284*M^2*N^2*s1^2+N^2*s1^2-2*M^11*N*s1^2+18*M^9*N*s1^2-44*M^7*N*s1^2+44*M^5*N*s1^2-18*M^3*N*s1^2+2*M*N*s1^2+M^10*s1^2-4*M^8*s1^2+6*M^6*s1^2-4*M^4*s1^2+M^2*s1^2-2*M^10*N^12*s1+4*M^6*N^12*s1-2*M^2*N^12*s1-4*M^11*N^11*s1+300*M^9*N^11*s1-848*M^7*N^11*s1+848*M^5*N^11*s1-300*M^3*N^11*s1+4*M*N^11*s1-2*M^12*N^10*s1+352*M^10*N^10*s1-4606*M