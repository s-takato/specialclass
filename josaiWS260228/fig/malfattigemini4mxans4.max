endstep$/*##*/
val13MNn: num(val13MN)$/*##*/
fcL: args(val13MNn)$/*##*/
lenFCL: length(fcL)$/*##*/
linF: sublist(fcL, lambda([f], hipow(f,s1)=1))$/*##*/
sols: map(lambda([eq], solve(eq,s1)[1]), linF)$/*##*/
ansL: map(rhs, sols)$/*##*/
subRule: [m=2*M/(1-M^2), n=2*N/(1-N^2)]$/*##*/
assume(M>0, M<1, N>0, N<1)$/*##*/
eq1MN: numer(radcan(subst(subRule, eq1)))$/*##*/
eq3MN: numer(radcan(subst(subRule, eq3)))$/*##*/
solveS2(valS1) := map(lambda([e], factor(rhs(e))), solve(numer(radcan(subst(s1=valS1, eq1MN))), s2))$/*##*/
solveS3(valS1) := map(lambda([e], factor(rhs(e))), solve(numer(radcan(subst(s1=valS1, eq3MN))), s3))$/*##*/
s2solList: map(solveS2, ansL)$/*##*/
s3solList: map(solveS3, ansL)$/*##*/
ans123L: []$/*##*/
for k:1 thru length(ansL) do block(       s1v:ansL[k], list2:s2solList[k], list3:s3solList[k],       for v2 in list2 do (          for v3 in list3 do (            ans123L:endcons([s1v, v2, v3], ans123L) ) ) )$/*##*/
len:length(ans123L)$/*##*/
endstep$/*##*/
